apiVersion: 1

groups:
  - orgId: 1
    name: blackbox
    folder: Homelab
    interval: 1m
    rules:
      - uid: probe-service-down
        title: Service down
        condition: C
        for: 5m
        noDataState: NoData
        execErrState: Error
        isPaused: false
        labels:
          severity: critical
        annotations:
{% raw %}
          summary: "{{ $labels.instance }} is down"
          description: "Blackbox probe to {{ $labels.instance }} has been failing for 5 minutes."
{% endraw %}
        data:
          - refId: A
            relativeTimeRange: { from: 300, to: 0 }
            datasourceUid: prometheus
            model:
              refId: A
              expr: probe_success
              instant: true
          - refId: C
            relativeTimeRange: { from: 0, to: 0 }
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: A
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
                  query:
                    params: [A]
                  reducer:
                    type: last
                    params: []
                  type: query
